  "item": [
    {
      "name": "Create Book",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"{{randomBookTitle}}\",\n  \"author\": \"John Doe\",\n  \"year\": 2023\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/books",
          "host": ["{{baseUrl}}"],
          "path": ["books"]
        },
        "description": "Create a new book with a random title."
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Generate a random book title\nconst randomTitle = 'Book-' + Math.floor(Math.random() * 1000);\npm.collectionVariables.set('randomBookTitle', randomTitle);"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Check response time\npm.test('Response time is less than 500ms', function () {\n  pm.expect(pm.response.responseTime).to.be.below(500);\n});\n\n// Check status code\npm.test('Status code is 201', function () {\n  pm.expect(pm.response.code).to.equal(201);\n});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
